# Copy to .env and fill in. Used locally and mirrored on EAS / Render for production builds.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Hosted Expo Router web origin for auth email redirects (not localhost).
EXPO_PUBLIC_AUTH_REDIRECT_ORIGIN=

# Optional: full URL to privacy policy. After deploying mobile web to Render, set e.g.
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://shira-fit-mobile-web.onrender.com/privacy-policy
EXPO_PUBLIC_PRIVACY_POLICY_URL=

# Optional: Expo/EAS project UUID after running `npx eas-cli init` (also written into app config).
# EXPO_PUBLIC_EAS_PROJECT_ID=
