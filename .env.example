# Mobile (Expo) — copy to mobile/.env or use app.config.js extra
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Used for Supabase auth emails (confirm + reset). Must be a real reachable origin (NOT localhost).
# Example: https://app.shirafit.com
EXPO_PUBLIC_AUTH_REDIRECT_ORIGIN=

# Admin web (Vite)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Edge Functions (set in Dashboard → Functions → Secrets)
# SUPABASE_SERVICE_ROLE_KEY — auto in hosted functions
# CRON_SECRET — random string; send as Authorization: Bearer <CRON_SECRET> from Cron
